{
  "name": "battery-status",
  "version": "1.6.0",
  "description": "System-tray app showing the battery level of connected Bluetooth devices",
  "main": "out/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/intellinside/battery-status.git"
  },
  "author": {
    "name": "intellinside",
    "email": "devbyside@gmail.com"
  },
  "license": "MIT",
  "scripts": {
    "build:helper": "dotnet publish src/main/devicehelper/devicehelper.csproj -c Release -r win-x64 -o src/main/scripts --nologo -v quiet",
    "dev": "npm run build:helper && electron-vite dev",
    "build": "npm run build:helper && electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "dist": "npm run build:helper && electron-vite build && electron-builder",
    "dist:dir": "npm run build:helper && electron-vite build && electron-builder --dir"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "42.4.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.2",
    "vite": "7.3.5"
  },
  "allowScripts": {
    "electron@42.4.1": true
  }
}
